# Copy this file to `.env` for local development.
#
# User/org page:
#   ASTRO_SITE must be the site origin only, with no trailing slash.
#   ASTRO_SITE=https://username.github.io
#   ASTRO_BASE=
#
# Project page:
#   ASTRO_SITE=https://username.github.io
#   ASTRO_BASE=/repo-name

ASTRO_SITE=https://username.github.io
ASTRO_BASE=
