---
interface Props {
  doi?: string;
  altmetric?: boolean;
  dimensions?: boolean;
}

const { doi, altmetric = false, dimensions = false } = Astro.props;

const showAltmetric = !!doi && altmetric;
const showDimensions = !!doi && dimensions;
---

{
  showAltmetric && (
    <div class="altmetric-embed" data-badge-type="2" data-badge-popover="right" data-doi={doi} />
  )
}

{
  showDimensions && (
    <span
      class="__dimensions_badge_embed__"
      data-doi={doi}
      data-legend="hover-right"
      data-style="small_circle"
    />
  )
}

{showAltmetric && <script is:inline src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js" />}

{showDimensions && <script is:inline async src="https://badge.dimensions.ai/badge.js" />}
