---
import type { NavItem } from '@config/site';
import { site } from '@config/site';
import { getCollection } from 'astro:content';

const base = site.base || '';

// ── Navigation items — derived from site.navbar.items (single source of truth) ─
function flattenNav(items: NavItem[]) {
  return items.flatMap((item) => {
    if ('href' in item) {
      return [
        {
          id: `nav-${item.label}`,
          title: item.label.charAt(0).toUpperCase() + item.label.slice(1),
          section: 'Navigation',
          href: `${base}${item.href}`,
        },
      ];
    }
    // dropdown: include each child leaf
    return item.children.map((child) => ({
      id: `nav-${child.label}`,
      title: child.label.charAt(0).toUpperCase() + child.label.slice(1),
      section: 'Navigation',
      href: `${base}${child.href}`,
    }));
  });
}

const navItems = flattenNav(site.navbar.items);

// ── Content items (indexed at build time for dev-mode title search) ───────────
type SearchItem = { id: string; title: string; section: string; href: string; keywords: string };

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.hidden && !p.data.draft)
  .map(
    (p): SearchItem => ({
      id: `post-${p.id}`,
      title: p.data.title,
      section: 'Blog Posts',
      href: `${base}/blog/${p.id}/`,
      keywords: [...(p.data.tags ?? []), ...(p.data.categories ?? [])].join(' '),
    }),
  );

const projects = (await getCollection('projects')).map(
  (p): SearchItem => ({
    id: `project-${p.id}`,
    title: p.data.title,
    section: 'Projects',
    href: `${base}/projects/${p.id}/`,
    keywords: p.data.category ?? '',
  }),
);

const teaching = (await getCollection('teaching')).map(
  (t): SearchItem => ({
    id: `teaching-${t.id}`,
    title: t.data.title,
    section: 'Teaching',
    href: `${base}/teaching/`,
    keywords: t.data.term ?? '',
  }),
);

const allItems: SearchItem[] = [...posts, ...projects, ...teaching];
---

<!-- ninja-keys web component -->
<ninja-keys
  id="ninja-search"
  placeholder="Search or jump to…"
  hideBreadcrumbs
  data-nav-items={JSON.stringify(navItems)}
  data-content-items={JSON.stringify(allItems)}
  data-pagefind-base={base}></ninja-keys>

<script>
  import 'ninja-keys';

  type RawItem = { id: string; title: string; section: string; href: string; keywords?: string };

  function buildAction(item: RawItem) {
    return {
      id: item.id,
      title: item.title,
      section: item.section,
      handler: () => {
        window.location.href = item.href;
      },
    };
  }

  async function initSearch() {
    await customElements.whenDefined('ninja-keys');

    const nk = document.querySelector('#ninja-search') as any;
    if (!nk) return;

    const el = nk as HTMLElement;
    const navItems: RawItem[] = JSON.parse(el.dataset.navItems ?? '[]');
    const contentItems: RawItem[] = JSON.parse(el.dataset.contentItems ?? '[]');
    const pagefindBase = el.dataset.pagefindBase ?? '';

    const navData = navItems.map(buildAction);
    const contentData = contentItems.map(buildAction);
    const defaultData = [...navData, ...contentData];

    nk.data = navData; // show nav items while idle

    // Open on search button click
    document.querySelectorAll('#search-toggle').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        nk.open();
      });
    });

    // ⌘K / Ctrl+K
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        nk.open();
      }
    });

    // Pagefind — lazy-loaded on first search query
    let pagefind: any = null;
    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import(/* @vite-ignore */ `${pagefindBase}/pagefind/pagefind.js`);
        await pagefind.init();
      } catch {
        pagefind = null;
      }
      return pagefind;
    }

    nk.addEventListener('change', async (e: CustomEvent) => {
      const query = (e.detail?.search ?? '').trim().toLowerCase();

      if (!query) {
        nk.data = navData;
        return;
      }

      // Try Pagefind first (full-text, available after yarn build)
      const pf = await loadPagefind();
      if (pf) {
        const response = await pf.search(query);
        const results = await Promise.all(response.results.slice(0, 10).map((r: any) => r.data()));
        if (results.length > 0) {
          nk.data = results.map((item: any) => ({
            id: item.url,
            title: item.meta?.title || item.url,
            section: 'Search Results',
            description: item.excerpt?.replace(/<[^>]*>/g, '') ?? '',
            handler: () => {
              window.location.href = item.url;
            },
          }));
          return;
        }
      }

      // Fallback: filter pre-built title/keyword index (works in dev mode too)
      const filtered = defaultData.filter((item) => {
        const raw =
          contentItems.find((c) => c.id === item.id) ?? navItems.find((n) => n.id === item.id);
        const haystack = `${item.title} ${raw?.keywords ?? ''}`.toLowerCase();
        return haystack.includes(query);
      });
      nk.data = filtered.length > 0 ? filtered : navData;
    });
  }

  // Sync .dark class with document theme so ninja-keys uses its built-in dark styles
  function syncNinjaTheme() {
    const el = document.getElementById('ninja-search');
    if (!el) return;
    el.classList.toggle('dark', document.documentElement.getAttribute('data-theme') === 'dark');
  }

  new MutationObserver(syncNinjaTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });

  syncNinjaTheme();
  initSearch();
  document.addEventListener('astro:after-swap', () => {
    syncNinjaTheme();
    initSearch();
  });
</script>

<style is:global>
  /* Base (light mode) theme */
  ninja-keys {
    --ninja-accent-color: var(--global-theme-color);
    --ninja-text-color: var(--global-text-color);
    --ninja-secondary-text-color: var(--global-text-color-light);
    --ninja-secondary-background-color: var(--global-divider-color);
    --ninja-selected-background: var(--global-theme-color);
    --ninja-icon-color: var(--global-text-color-light);
    --ninja-icon-size: 1rem;
    --ninja-separate-border: 1px solid var(--global-divider-color);
    --ninja-modal-background: var(--global-card-bg-color, var(--global-bg-color));
    --ninja-footer-background: var(--global-bg-color);
    --ninja-group-text-color: var(--global-text-color-light);
    --ninja-placeholder-color: var(--global-text-color-light);
    --ninja-z-index: 9999;
    --ninja-modal-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    --ninja-overflow-background: rgba(0, 0, 0, 0.5);
  }

  /* Dark mode — override ninja-keys' built-in .dark defaults to match our scheme */
  html[data-theme='dark'] ninja-keys {
    --ninja-text-color: var(--global-text-color); /* #e0e0e0 not ninja's dim #7d7d7d */
    --ninja-selected-text-color: var(--global-hover-text-color);
    --ninja-accent-color: var(--global-theme-color); /* cyan, not ninja's purple */
    --ninja-selected-background: var(--global-theme-color); /* cyan highlight */
    --ninja-modal-background: var(--global-card-bg-color); /* #212529 */
    --ninja-footer-background: var(--global-bg-color); /* #1c1c1d */
    --ninja-modal-shadow: 0 16px 70px rgba(0, 0, 0, 0.5);
    --ninja-overflow-background: rgba(0, 0, 0, 0.7);
  }
</style>
