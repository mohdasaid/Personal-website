---
interface Props {
  /** Main title line (job title, degree, paper title). */
  title: string;
  /** Secondary line (institution, company, journal). */
  subtitle?: string;
  /** Location string — shown below date badge. */
  location?: string;
  /** Date range or single date string (already formatted). */
  dates?: string;
  /** Bullet points. */
  highlights?: string[];
  /** URL to make the title a link. */
  url?: string;
}

const { title, subtitle, location, dates, highlights = [], url } = Astro.props;
---

<li class="list-group-item">
  <div class="row">
    <div class="col-xs-2 col-sm-2 col-md-2 date-column text-center">
      <table class="table-cv">
        <tbody>
          <tr>
            <td>
              {
                dates && (
                  <span
                    class="badge font-weight-bold danger-color-dark text-uppercase align-middle"
                    style="min-width: 75px;"
                  >
                    {dates}
                  </span>
                )
              }
            </td>
          </tr>
          {
            location && (
              <tr>
                <td>
                  <p class="location">{location}</p>
                </td>
              </tr>
            )
          }
        </tbody>
      </table>
    </div>
    <div class="col-xs-10 col-sm-10 col-md-10 mt-md-0 mt-2">
      {
        url ? (
          <h6 class="title font-weight-bold ml-md-4 ml-1">
            <a href={url} target="_blank" rel="noopener noreferrer">
              {title}
            </a>
          </h6>
        ) : (
          <h6 class="title font-weight-bold ml-md-4 ml-1">{title}</h6>
        )
      }
      {
        subtitle && (
          <h6 class="ml-md-4 ml-1" style="font-size: 0.95rem;">
            {subtitle}
          </h6>
        )
      }
      {
        highlights.length > 0 && (
          <ul class="items">
            {highlights.map((h) => (
              <li>
                <span class="item" set:html={h} />
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</li>
