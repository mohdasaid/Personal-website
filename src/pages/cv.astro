---
import CVEntry from '@components/cv/CVEntry.astro';
import CVSection from '@components/cv/CVSection.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { withBase } from '@utils/base';
import type { JSONResume, RenderCV, RenderCVEntry } from '@utils/cv';
import { formatCVDate, formatDateRange } from '@utils/cv';
import { Icon } from 'astro-icon/components';
import yaml from 'js-yaml';

import cvRaw from '../data/cv.yml?raw';
import resumeData from '../data/resume.json';

const format = site.cv.format;

const renderCV = format === 'rendercv' ? (yaml.load(cvRaw) as RenderCV) : null;
const jsonResume = format === 'jsonresume' ? (resumeData as JSONResume) : null;

const rc = renderCV?.cv ?? null;
const education = (rc?.sections?.education ?? []) as RenderCVEntry[];
const experience = (rc?.sections?.experience ?? []) as RenderCVEntry[];
const rcPublications = (rc?.sections?.publications ?? []) as RenderCVEntry[];
const awards = (rc?.sections?.awards ?? []) as RenderCVEntry[];
const skills = (rc?.sections?.skills ?? []) as RenderCVEntry[];
const interests = (rc?.sections?.interests ?? []) as RenderCVEntry[];

const jr = jsonResume ?? null;
const jrLabel = jr?.basics?.label ?? '';

// Build sidebar TOC items based on which sections have data
type TocItem = { label: string; href: string };

const tocItems: TocItem[] = [];
if (format === 'rendercv' && rc) {
  if (rc.name || rc.email || rc.phone) tocItems.push({ label: 'Contact Information', href: '#contact' });
  if (rc.summary) tocItems.push({ label: 'Professional Summary', href: '#summary' });
  if (education.length > 0) tocItems.push({ label: 'Education', href: '#education' });
  if (experience.length > 0) tocItems.push({ label: 'Experience', href: '#experience' });
  if (rcPublications.length > 0) tocItems.push({ label: 'Publications', href: '#publications' });
  if (awards.length > 0) tocItems.push({ label: 'Awards', href: '#awards' });
  if (skills.length > 0) tocItems.push({ label: 'Skills', href: '#skills' });
  if (interests.length > 0) tocItems.push({ label: 'Interests', href: '#interests' });
} else if (format === 'jsonresume' && jr) {
  if (jr.basics) tocItems.push({ label: 'Contact Information', href: '#contact' });
  if (jr.work?.length) tocItems.push({ label: 'Experience', href: '#experience' });
  if (jr.education?.length) tocItems.push({ label: 'Education', href: '#education' });
  if (jr.publications?.length) tocItems.push({ label: 'Publications', href: '#publications' });
  if (jr.awards?.length) tocItems.push({ label: 'Awards', href: '#awards' });
  if (jr.skills?.length) tocItems.push({ label: 'Skills', href: '#skills' });
  if (jr.languages?.length) tocItems.push({ label: 'Languages', href: '#languages' });
  if (jr.interests?.length) tocItems.push({ label: 'Interests', href: '#interests' });
}
---

<Page title="CV" description={`Curriculum vitae of ${site.author.name}`}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">
        cv
        {site.cv.pdfPath && (
          <a
            href={withBase(site.cv.pdfPath)}
            target="_blank"
            rel="noopener noreferrer"
            class="float-right"
            aria-label="Download CV PDF"
          >
            <Icon name="fa-solid:file-pdf" />
          </a>
        )}
      </h1>
    </header>

    <article>
      <div class="cv-page-wrapper">
        <!-- Sidebar TOC -->
        {tocItems.length > 0 && (
          <nav class="cv-sidebar-toc" aria-label="CV sections">
            <ul>
              {tocItems.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        <!-- CV content -->
        <div class="cv">

          <!-- ── RENDERCV ──────────────────────────────────────────────── -->
          {format === 'rendercv' && renderCV && (
            <>
              {rc && (rc.name || rc.email || rc.phone || rc.website || rc.location) && (
                <>
                  <a class="anchor" id="contact"></a>
                  <div class="card mt-3 p-3">
                    <h3 class="card-title font-weight-medium">Contact Information</h3>
                    <table class="table table-cv table-sm table-borderless">
                      {rc.name && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Name</b></td>
                          <td class="p-1 pl-2 font-weight-light">{rc.name}</td>
                        </tr>
                      )}
                      {rc.email && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Email</b></td>
                          <td class="p-1 pl-2 font-weight-light">{rc.email}</td>
                        </tr>
                      )}
                      {rc.phone && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Phone</b></td>
                          <td class="p-1 pl-2 font-weight-light">{rc.phone}</td>
                        </tr>
                      )}
                      {rc.location && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Location</b></td>
                          <td class="p-1 pl-2 font-weight-light">{rc.location}</td>
                        </tr>
                      )}
                      {rc.website && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Website</b></td>
                          <td class="p-1 pl-2 font-weight-light">
                            <a href={rc.website} target="_blank" rel="noopener noreferrer">{rc.website}</a>
                          </td>
                        </tr>
                      )}
                    </table>
                  </div>
                </>
              )}

                {rc?.summary && (
                <>
                  <a class="anchor" id="summary"></a>
                  <div class="card mt-3 p-3">
                    <h3 class="card-title font-weight-medium">Professional Summary</h3>
                    <p class="card-text font-weight-light">{rc.summary}</p>
                  </div>
                </>
              )}

            {education.length > 0 && (
                <CVSection title="Education" id="education">
                  <ul class="card-text font-weight-light list-group list-group-flush">
                    {education.map((e) => (
                      <CVEntry
                        title={[e.degree, e.area].filter(Boolean).join(' in ')}
                        subtitle={e.institution}
                        location={e.location}
                        dates={formatDateRange(e.start_date, e.end_date)}
                        highlights={e.highlights}
                      />
                    ))}
                  </ul>
                </CVSection>
              )}

              {experience.length > 0 && (
                <CVSection title="Experience" id="experience">
                  <ul class="card-text font-weight-light list-group list-group-flush">
                    {experience.map((e) => (
                      <CVEntry
                        title={e.position ?? ''}
                        subtitle={e.company}
                        location={e.location}
                        dates={formatDateRange(e.start_date, e.end_date)}
                        highlights={e.highlights}
                      />
                    ))}
                  </ul>
                </CVSection>
              )}

              {rcPublications.length > 0 && (
                <CVSection title="Selected Publications" id="publications">
                  <ul class="card-text font-weight-light list-group list-group-flush">
                    {rcPublications.map((e) => (
                      <CVEntry
                        title={e.title ?? ''}
                        subtitle={[e.authors?.join(', '), e.journal].filter(Boolean).join(' — ')}
                        dates={formatCVDate(e.date)}
                        url={e.doi ? `https://doi.org/${e.doi}` : e.url}
                      />
                    ))}
                  </ul>
                </CVSection>
              )}

              {awards.length > 0 && (
                <CVSection title="Honors &amp; Awards" id="awards">
                  <ul class="card-text font-weight-light list-group list-group-flush">
                    {awards.map((e) => (
                      <CVEntry
                        title={e.name ?? ''}
                        subtitle={e.issuer}
                        dates={formatCVDate(e.date)}
                        highlights={e.highlights}
                      />
                    ))}
                  </ul>
                </CVSection>
              )}

              {skills.length > 0 && (
                <CVSection title="Skills" id="skills">
                  <div class="card-text font-weight-light">
                    {skills.map((e) => (
                      <div class="skill-item">
                        <strong>{e.label}:</strong>{' '}{e.details}
                      </div>
                    ))}
                  </div>
                </CVSection>
              )}

              {interests.length > 0 && (
                <CVSection title="Interests" id="interests">
                  <div class="card-text font-weight-light">
                    {interests.map((e) => (
                      <div class="skill-item">
                        <strong>{e.label}:</strong>{' '}{e.details}
                      </div>
                    ))}
                  </div>
                </CVSection>
              )}
            </>
          )}

          <!-- ── JSONRESUME ─────────────────────────────────────────────── -->
          {format === 'jsonresume' && jsonResume && (
            <>
              {jr?.basics && (
                <>
                  <a class="anchor" id="contact"></a>
                  <div class="card mt-3 p-3">
                    <h3 class="card-title font-weight-medium">Contact Information</h3>
                    <table class="table table-cv table-sm table-borderless">
                      {jr.basics.name && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Name</b></td>
                          <td class="p-1 pl-2 font-weight-light">{jr.basics.name}</td>
                        </tr>
                      )}
                      {jrLabel && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Professional Title</b></td>
                          <td class="p-1 pl-2 font-weight-light">{jrLabel}</td>
                        </tr>
                      )}
                      {jr.basics.email && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Email</b></td>
                          <td class="p-1 pl-2 font-weight-light">{jr.basics.email}</td>
                        </tr>
                      )}
                      {jr.basics.phone && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Phone</b></td>
                          <td class="p-1 pl-2 font-weight-light">{jr.basics.phone}</td>
                        </tr>
                      )}
                      {jr.basics.url && (
                        <tr>
                          <td class="p-1 pr-2 font-weight-bold"><b>Website</b></td>
                          <td class="p-1 pl-2 font-weight-light">
                            <a href={jr.basics.url} target="_blank" rel="noopener noreferrer">{jr.basics.url}</a>
                          </td>
                        </tr>
                      )}
                    </table>
                  </div>
                </>
              )}

              {jr?.work && jr.work.length > 0 && (
                <CVSection title="Experience" id="experience">
                  <ul class="card-text font-weight-light list-group list-group-flush">
                    {jr.work.map((e) => (
                      <CVEntry
                        title={e.position ?? ''}
                        subtitle={e.name}
                        url={e.url}
                        dates={formatDateRange(e.startDate, e.endDate)}
                        highlights={e.highlights}
                      />
                    ))}
                  </ul>
                </CVSection>
              )}

              {jr?.education && jr.education.length > 0 && (
                <CVSection title="Education" id="education">
                  <ul class="card-text font-weight-light list-group list-group-flush">
                    {jr.education.map((e) => (
                      <CVEntry
                        title={[e.studyType, e.area].filter(Boolean).join(' in ')}
                        subtitle={e.institution}
                        url={e.url}
                        dates={formatDateRange(e.startDate, e.endDate)}
                        highlights={e.courses}
                      />
                    ))}
                  </ul>
                </CVSection>
              )}

              {jr?.publications && jr.publications.length > 0 && (
                <CVSection title="Selected Publications" id="publications">
                  <ul class="card-text font-weight-light list-group list-group-flush">
                    {jr.publications.map((e) => (
                      <CVEntry
                        title={e.name ?? ''}
                        subtitle={e.publisher}
                        url={e.url}
                        dates={formatCVDate(e.releaseDate)}
                        highlights={e.summary ? [e.summary] : []}
                      />
                    ))}
                  </ul>
                </CVSection>
              )}

              {jr?.awards && jr.awards.length > 0 && (
                <CVSection title="Honors &amp; Awards" id="awards">
                  <ul class="card-text font-weight-light list-group list-group-flush">
                    {jr.awards.map((e) => (
                      <CVEntry
                        title={e.title ?? ''}
                        subtitle={e.awarder}
                        dates={formatCVDate(e.date)}
                        highlights={e.summary ? [e.summary] : []}
                      />
                    ))}
                  </ul>
                </CVSection>
              )}

              {jr?.skills && jr.skills.length > 0 && (
                <CVSection title="Skills" id="skills">
                  <div class="card-text font-weight-light">
                    {jr.skills.map((e) => (
                      <div class="skill-item">
                        <strong>{e.name}:</strong>{' '}{e.keywords?.join(', ')}
                      </div>
                    ))}
                  </div>
                </CVSection>
              )}

              {jr?.languages && jr.languages.length > 0 && (
                <CVSection title="Languages" id="languages">
                  <div class="card-text font-weight-light">
                    {jr.languages.map((e) => (
                      <div class="skill-item">
                        <strong>{e.language}:</strong>{' '}{e.fluency}
                      </div>
                    ))}
                  </div>
                </CVSection>
              )}

              {jr?.interests && jr.interests.length > 0 && (
                <CVSection title="Interests" id="interests">
                  <div class="card-text font-weight-light">
                    {jr.interests.map((e) => (
                      <div class="skill-item">
                        <strong>{e.name}:</strong>{' '}{e.keywords?.join(', ')}
                      </div>
                    ))}
                  </div>
                </CVSection>
              )}
            </>
          )}

        </div><!-- /.cv -->
      </div><!-- /.cv-page-wrapper -->
    </article>
  </div>
</Page>

<style>
  /* Two-column layout: sidebar + content */
  .cv-page-wrapper {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  /* Sticky left sidebar TOC */
  .cv-sidebar-toc {
    flex-shrink: 0;
    width: 180px;
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
  }

  .cv-sidebar-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid var(--global-divider-color);
  }

  .cv-sidebar-toc li a {
    display: block;
    padding: 0.3rem 0 0.3rem 0.75rem;
    font-size: 0.8rem;
    color: var(--global-text-color-light);
    text-decoration: none;
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .cv-sidebar-toc li a:hover {
    color: var(--global-theme-color);
  }

  /* Main CV content fills remaining space */
  .cv {
    flex: 1;
    min-width: 0;
  }

  /* Hide sidebar on small screens */
  @media (max-width: 768px) {
    .cv-page-wrapper {
      flex-direction: column;
    }
    .cv-sidebar-toc {
      display: none;
    }
  }
</style>
