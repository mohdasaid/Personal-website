---
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

const all = await getCollection('teaching');

// Extract year from term string, e.g. "Fall 2024" → 2024
function termYear(term?: string): number {
  if (!term) return 0;
  const m = term.match(/\d{4}/);
  return m ? parseInt(m[0]) : 0;
}

// Pre-render all entries
const rendered = await Promise.all(all.map(async (c) => ({ entry: c, rendered: await render(c) })));

// Build year → entries map (sorted descending by year, then by importance)
const byYear = new Map<number, typeof rendered>();
for (const item of rendered) {
  const year = termYear(item.entry.data.term);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(item);
}
for (const items of byYear.values()) {
  items.sort((a, b) => (a.entry.data.importance ?? 999) - (b.entry.data.importance ?? 999));
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const calendarId = site.teaching.calendarId;
const timezone = site.teaching.timezone;
---

<Page title="Teaching" description={`Teaching by ${site.author.name}`}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">teaching</h1>
      <p class="post-description">{site.pages.teaching.description}</p>
    </header>

    <article>
      <!-- Google Calendar section -->
      {
        calendarId && (
          <div class="post mt-4">
            <h2 class="mb-3">
              <Icon name="fa-solid:calendar" style="font-size: 0.9em; margin-right: 0.4em;" />
              Upcoming Events
            </h2>
            <button
              class="btn-calendar-toggle"
              id="calendar-toggle-btn"
              aria-expanded="false"
              aria-controls="calendar-container"
              aria-label="Show calendar"
            >
              Show Calendar
            </button>
            <div id="calendar-container" style="display: none;">
              <iframe
                id="calendar-iframe"
                data-calendar-id={calendarId}
                data-timezone={timezone}
                style="border: 0; width: 100%; height: 600px;"
                frameborder="0"
                scrolling="no"
              />
            </div>
          </div>
        )
      }

      <!-- Courses grouped by year -->
      {
        all.length === 0 ? (
          <p style="color: var(--global-text-color-light);">No teaching entries yet.</p>
        ) : (
          <div class="courses">
            {years.map((year) => (
              <>
                <h2 class="year">{year > 0 ? year : 'Other'}</h2>
                <div class="course-list">
                  {byYear.get(year)!.map(({ entry: course, rendered: { Content } }) => (
                    <div class="course-item">
                      <h3 class="course-title">
                        {course.data.url ? (
                          <a href={course.data.url} target="_blank" rel="noopener noreferrer">
                            {course.data.title}
                          </a>
                        ) : (
                          course.data.title
                        )}
                      </h3>
                      <div class="course-meta">
                        {course.data.code && <span class="course-term">{course.data.code}</span>}
                        {course.data.term && <span class="course-term">{course.data.term}</span>}
                        {course.data.institution && (
                          <span class="course-instructor">{course.data.institution}</span>
                        )}
                      </div>
                      {course.data.description && (
                        <div class="course-description">
                          <p>{course.data.description}</p>
                        </div>
                      )}
                      <div class="prose prose-sm mt-2 max-w-none">
                        <Content />
                      </div>
                    </div>
                  ))}
                </div>
              </>
            ))}
          </div>
        )
      }
    </article>
  </div>
</Page>

<script>
  function initCalendar() {
    const btn = document.getElementById('calendar-toggle-btn') as HTMLButtonElement | null;
    const container = document.getElementById('calendar-container') as HTMLDivElement | null;
    const iframe = document.getElementById('calendar-iframe') as HTMLIFrameElement | null;
    if (!btn || !container || !iframe) return;

    function getCalendarBgColor() {
      const theme = document.documentElement.getAttribute('data-theme');
      const isDark =
        theme === 'dark' ||
        (theme === null && window.matchMedia('(prefers-color-scheme: dark)').matches);
      return isDark ? '333333' : 'f9f9f9';
    }

    function buildCalendarUrl() {
      const calendarId = iframe!.dataset.calendarId;
      const timezone = iframe!.dataset.timezone || 'UTC';
      if (!calendarId) return '';
      const params = new URLSearchParams({
        src: calendarId,
        ctz: timezone,
        mode: 'WEEK',
        showTitle: '0',
        showPrint: '0',
        showCalendars: '0',
        showTabs: '0',
        bgcolor: getCalendarBgColor(),
      });
      return `https://calendar.google.com/calendar/embed?${params.toString()}`;
    }

    btn.addEventListener('click', () => {
      const isHidden = container!.style.display === 'none';
      container!.style.display = isHidden ? 'block' : 'none';
      btn.textContent = isHidden ? 'Hide Calendar' : 'Show Calendar';
      btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
      btn.setAttribute('aria-label', isHidden ? 'Hide calendar' : 'Show calendar');
      if (isHidden && iframe!.src === '') {
        iframe!.src = buildCalendarUrl();
      }
    });
  }

  document.addEventListener('astro:page-load', initCalendar);
</script>
