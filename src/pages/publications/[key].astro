---
import { InspireHEPBadge } from '@components/publications/InspireHEPBadge.tsx';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import type { CoauthorMap } from '@utils/authors';
import { linkAuthors } from '@utils/authors';
import { withBase } from '@utils/base';
import {
  getAuthors,
  getCleanBibtex,
  getTitle,
  getVenue,
  getYear,
  parseBibtex,
} from '@utils/bibtex';
import yaml from 'js-yaml';

import citationsRaw from '../../data/citations.yml?raw';
import coauthorsRaw from '../../data/coauthors.yml?raw';
import bibRaw from '../../data/papers.bib?raw';

export async function getStaticPaths() {
  const entries = parseBibtex(bibRaw);
  return entries.map((entry) => ({
    params: { key: entry.key },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const title = getTitle(entry);
const authorsRaw = getAuthors(entry);
const venue = getVenue(entry);
const year = getYear(entry);
const yearStr = year > 0 ? String(year) : undefined;
const abstract = entry.fields.abstract;
const doi = entry.fields.doi;
const arxiv = entry.fields.arxiv;
const hal = entry.fields.hal;
const htmlLink = entry.fields.html;
const pdfPath = entry.fields.pdf;
const supp = entry.fields.supp;
const code = entry.fields.code;
const slides = entry.fields.slides;
const poster = entry.fields.poster;
const video = entry.fields.video;
const blog = entry.fields.blog;
const website = entry.fields.website;
const award = entry.fields.award;
const awardName = entry.fields.award_name;
const annotation = entry.fields.annotation;
const additionalInfo = entry.fields.additional_info;
const googleScholarId = entry.fields.google_scholar_id;
const inspirehepId = entry.fields.inspirehep_id;
const altmetricField = entry.fields.altmetric;
const dimensionsField = entry.fields.dimensions;
const pdfDir = withBase(site.publications.pdfDir);
const scholarUserId = site.socials.scholar_userid ?? '';

const pdfHref = pdfPath
  ? pdfPath.startsWith('http')
    ? pdfPath
    : `${pdfDir}${pdfPath}`
  : undefined;

const suppHref = supp ? (supp.startsWith('http') ? supp : `${pdfDir}${supp}`) : undefined;

const slidesHref = slides ? (slides.startsWith('http') ? slides : `${pdfDir}${slides}`) : undefined;

const posterHref = poster ? (poster.startsWith('http') ? poster : `${pdfDir}${poster}`) : undefined;

// Load co-author links
const coauthors = (yaml.load(coauthorsRaw) ?? {}) as CoauthorMap;
const authorLastName = site.publications.authorLastName ?? site.author.name.split(' ').pop() ?? '';
const authorLinks = linkAuthors(authorsRaw.split(', '), coauthors, authorLastName);

// Google Scholar badge — two variants for light/dark theme
const citations = (yaml.load(citationsRaw) ?? {}) as Record<string, number>;
const scholarCount = googleScholarId ? citations[googleScholarId] : undefined;
const scholarLabel =
  scholarCount !== undefined
    ? scholarCount >= 1000
      ? `${Math.round(scholarCount / 100) / 10}K`
      : String(scholarCount)
    : 'cite';
const scholarProfileUrl =
  googleScholarId && scholarUserId
    ? `https://scholar.google.com/citations?view_op=view_citation&hl=en&user=${scholarUserId}&citation_for_view=${scholarUserId}:${googleScholarId}`
    : undefined;
const scholarBadgeLight = scholarProfileUrl
  ? `https://img.shields.io/badge/scholar-${encodeURIComponent(scholarLabel)}-4285F4?logo=googlescholar&labelColor=f6f8fa&style=flat`
  : undefined;
const scholarBadgeDark = scholarProfileUrl
  ? `https://img.shields.io/badge/scholar-${encodeURIComponent(scholarLabel)}-4c8bf5?logo=googlescholar&labelColor=21262d&logoColor=8ab4f8&style=flat`
  : undefined;

// Altmetric: explicit ID overrides DOI/arXiv when value is not "true"
const altmetricExplicitId =
  altmetricField && altmetricField !== 'true' ? altmetricField : undefined;
const showAltmetric = !!(
  site.publications.badges.altmetric &&
  altmetricField &&
  (altmetricExplicitId || doi || arxiv)
);
const showDimensions = !!(site.publications.badges.dimensions && dimensionsField && doi);
const showGoogleScholar = !!(
  site.publications.badges.googleScholar &&
  googleScholarId &&
  scholarUserId
);
const showInspireHEP = !!(site.publications.badges.inspirehep && inspirehepId);
const hasBadges = showAltmetric || showDimensions || showGoogleScholar || showInspireHEP;

const bibtexBlock = getCleanBibtex(entry);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: title,
  author: authorsRaw.split(', ').map((name) => ({ '@type': 'Person', name })),
  ...(yearStr ? { datePublished: yearStr } : {}),
  ...(venue ? { isPartOf: { '@type': 'Periodical', name: venue } } : {}),
  ...(doi ? { identifier: { '@type': 'PropertyValue', propertyID: 'doi', value: doi } } : {}),
  ...(htmlLink ? { url: htmlLink } : doi ? { url: `https://doi.org/${doi}` } : {}),
  ...(abstract ? { abstract } : {}),
};

const canonicalURL = new URL(`${site.base}/publications/${entry.key}/`, site.url).toString();
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Publications',
      item: new URL(`${site.base}/publications/`, site.url).toString(),
    },
    { '@type': 'ListItem', position: 2, name: title, item: canonicalURL },
  ],
};
---

<Page title={title} description={abstract ?? `${title} by ${authorsRaw}`}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    <!-- Highwire Press meta tags for Google Scholar indexing -->
    <meta name="citation_title" content={title} />
    {authorsRaw.split(', ').map((a) => <meta name="citation_author" content={a} />)}
    {yearStr && <meta name="citation_publication_date" content={yearStr} />}
    {venue && <meta name="citation_journal_title" content={venue} />}
    {doi && <meta name="citation_doi" content={doi} />}
    {
      pdfHref && (
        <meta
          name="citation_pdf_url"
          content={pdfHref.startsWith('http') ? pdfHref : new URL(pdfHref, site.url).toString()}
        />
      )
    }
    <!-- Badge scripts (loaded only when at least one badge is enabled for this entry) -->
    {
      showAltmetric && (
        <script is:inline src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js" />
      )
    }
    {showDimensions && <script is:inline async src="https://badge.dimensions.ai/badge.js" />}
  </Fragment>

  <div class="post">
    <nav aria-label="Breadcrumb" class="breadcrumb-nav">
      <a href={`${site.base}/publications/`} class="breadcrumb-link">← Publications</a>
    </nav>

    <header class="post-header">
      <h1 class="post-title">{title}</h1>

      <!-- Authors with co-author links and self-identification -->
      <p class="pub-authors">
        {
          authorLinks.map((al, i) => (
            <>
              {al.url ? (
                <a href={al.url} target="_blank" rel="noopener noreferrer">
                  {al.isSelf ? <em>{al.name}</em> : al.name}
                </a>
              ) : al.isSelf ? (
                <em>{al.name}</em>
              ) : (
                al.name
              )}
              {i < authorLinks.length - 1 && ', '}
            </>
          ))
        }
        {
          (venue || yearStr) && (
            <em>
              {' '}
              &middot; {venue}
              {venue && yearStr ? ', ' : ''}
              {yearStr}
            </em>
          )
        }
        {additionalInfo && <span class="additional-info"> · {additionalInfo}</span>}
      </p>

      {annotation && <p class="pub-annotation">{annotation}</p>}

      {
        award && (
          <p>
            <span class="award-badge">{awardName ?? award}</span>
          </p>
        )
      }
    </header>

    <article>
      <!-- Action buttons: full set matching the index page -->
      <div class="pub-actions">
        {
          htmlLink && (
            <a href={htmlLink} target="_blank" rel="noopener noreferrer" class="btn">
              HTML
            </a>
          )
        }
        {
          doi && (
            <a
              href={`https://doi.org/${doi}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn"
            >
              DOI
            </a>
          )
        }
        {
          arxiv && (
            <a
              href={`https://arxiv.org/abs/${arxiv}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn"
            >
              arXiv
            </a>
          )
        }
        {
          hal && (
            <a
              href={`https://hal.science/${hal}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn"
            >
              HAL
            </a>
          )
        }
        {
          pdfHref && (
            <a href={pdfHref} target="_blank" rel="noopener noreferrer" class="btn">
              PDF
            </a>
          )
        }
        {
          suppHref && (
            <a href={suppHref} target="_blank" rel="noopener noreferrer" class="btn">
              Supp
            </a>
          )
        }
        {
          slidesHref && (
            <a href={slidesHref} target="_blank" rel="noopener noreferrer" class="btn">
              Slides
            </a>
          )
        }
        {
          posterHref && (
            <a href={posterHref} target="_blank" rel="noopener noreferrer" class="btn">
              Poster
            </a>
          )
        }
        {
          video && (
            <a href={video} target="_blank" rel="noopener noreferrer" class="btn">
              Video
            </a>
          )
        }
        {
          code && (
            <a href={code} target="_blank" rel="noopener noreferrer" class="btn">
              Code
            </a>
          )
        }
        {
          blog && (
            <a href={blog} target="_blank" rel="noopener noreferrer" class="btn">
              Blog
            </a>
          )
        }
        {
          website && (
            <a href={website} target="_blank" rel="noopener noreferrer" class="btn">
              Website
            </a>
          )
        }
      </div>

      <!-- Metric badges row -->
      {
        hasBadges && (
          <div class="pub-badges">
            {showAltmetric && (
              <>
                {altmetricExplicitId ? (
                  <div
                    class="altmetric-embed"
                    data-badge-type="2"
                    data-badge-popover="right"
                    data-altmetric-id={altmetricExplicitId}
                  />
                ) : doi ? (
                  <div
                    class="altmetric-embed"
                    data-badge-type="2"
                    data-badge-popover="right"
                    data-doi={doi}
                  />
                ) : (
                  <div
                    class="altmetric-embed"
                    data-badge-type="2"
                    data-badge-popover="right"
                    data-arxiv-id={arxiv}
                  />
                )}
              </>
            )}
            {showDimensions && doi && (
              <span
                class="__dimensions_badge_embed__"
                data-doi={doi}
                data-legend="hover-right"
                data-style="small_rectangle"
              />
            )}
            {showGoogleScholar && scholarBadgeLight && scholarBadgeDark && scholarProfileUrl && (
              <a
                href={scholarProfileUrl}
                target="_blank"
                rel="noopener noreferrer"
                style="line-height:0"
              >
                <img
                  src={scholarBadgeLight}
                  alt={
                    scholarCount !== undefined
                      ? `Google Scholar: ${scholarCount} citations`
                      : 'Google Scholar'
                  }
                  class="only-light"
                  loading="lazy"
                  style="height:20px;vertical-align:middle"
                />
                <img
                  src={scholarBadgeDark}
                  alt={
                    scholarCount !== undefined
                      ? `Google Scholar: ${scholarCount} citations`
                      : 'Google Scholar'
                  }
                  class="only-dark"
                  loading="lazy"
                  style="height:20px;vertical-align:middle"
                />
              </a>
            )}
            {showInspireHEP && inspirehepId && (
              <InspireHEPBadge client:load inspirehepId={inspirehepId} />
            )}
          </div>
        )
      }

      {
        abstract && (
          <section class="pub-section">
            <h2>Abstract</h2>
            <p>{abstract}</p>
          </section>
        )
      }

      <section class="pub-section">
        <h2>Citation</h2>
        <pre class="bibtex-block"><code>{bibtexBlock}</code></pre>
      </section>
    </article>
  </div>
</Page>

<style>
  .pub-authors {
    color: var(--global-text-color-light);
    margin-bottom: 0.5rem;
  }

  .pub-authors a {
    text-decoration: underline;
    color: inherit;
  }

  .pub-annotation {
    font-size: 0.875rem;
    color: var(--global-text-color-light);
    font-style: italic;
    margin-bottom: 0.5rem;
  }

  .additional-info {
    font-size: 0.875rem;
  }

  .award-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: #f59e0b;
    color: #fff;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .pub-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .pub-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    min-height: 24px;
  }

  /* Soften third-party Altmetric/Dimensions widgets in dark mode */
  html[data-theme='dark'] .pub-badges .altmetric-embed,
  html[data-theme='dark'] .pub-badges .__dimensions_badge_embed__ {
    filter: brightness(0.85) contrast(1.1) saturate(0.9);
  }

  .btn {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--global-theme-color);
    border-radius: 4px;
    color: var(--global-theme-color);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      background 0.15s,
      color 0.15s;
  }

  .btn:hover {
    background: var(--global-theme-color);
    color: var(--global-hover-text-color);
  }

  .pub-section {
    margin-top: 2rem;
  }

  .pub-section h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--global-divider-color);
  }

  .pub-section p {
    line-height: 1.7;
  }

  .bibtex-block {
    background: var(--global-card-bg-color);
    border: 1px solid var(--global-divider-color);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.8rem;
    white-space: pre;
  }
</style>
