---
import BibSearch from '@components/publications/BibSearch.tsx';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import type { CoauthorMap } from '@utils/authors';
import { withBase } from '@utils/base';
import { getAuthors, getTitle, getVenue, parseBibtex } from '@utils/bibtex';
import yaml from 'js-yaml';

import citationsRaw from '../../data/citations.yml?raw';
import coauthorsRaw from '../../data/coauthors.yml?raw';
import bibRaw from '../../data/papers.bib?raw';

const entries = parseBibtex(bibRaw).sort((a, b) => {
  const yearA = parseInt(a.fields.year ?? '0', 10);
  const yearB = parseInt(b.fields.year ?? '0', 10);
  return yearB - yearA;
});

const coauthors = (yaml.load(coauthorsRaw) ?? {}) as CoauthorMap;
const citations = (yaml.load(citationsRaw) ?? {}) as Record<string, number>;

const showAltmetric = site.publications.badges.altmetric;
const showDimensions = site.publications.badges.dimensions;
const maxAuthorLimit = site.publications.maxAuthorLimit;
const showThumbnails = site.publications.thumbnails;
const authorLastName = site.publications.authorLastName ?? site.author.name.split(' ').pop() ?? '';
const { labels } = site.publications;
const previewDir = withBase(site.publications.previewDir);
const pdfDir = withBase(site.publications.pdfDir);
const scholarUserId = site.socials.scholar_userid ?? '';
const badges = site.publications.badges;
---

<Page title="Publications" description={`Publications by ${site.author.name}`}>
  <!-- Highwire Press citation meta tags — required for Google Scholar indexing -->
  <Fragment slot="head">
    {
      entries.map((entry) => {
        const authors = getAuthors(entry).split(', ');
        return (
          <>
            <meta name="citation_title" content={getTitle(entry)} />
            {authors.map((author) => (
              <meta name="citation_author" content={author} />
            ))}
            {entry.fields.year && (
              <meta name="citation_publication_date" content={entry.fields.year} />
            )}
            {getVenue(entry) && <meta name="citation_journal_title" content={getVenue(entry)} />}
            {entry.fields.volume && <meta name="citation_volume" content={entry.fields.volume} />}
            {entry.fields.pdf && (
              <meta
                name="citation_pdf_url"
                content={
                  entry.fields.pdf.startsWith('http')
                    ? entry.fields.pdf
                    : new URL(`${pdfDir}${entry.fields.pdf}`, site.url).toString()
                }
              />
            )}
            {entry.fields.doi && <meta name="citation_doi" content={entry.fields.doi} />}
          </>
        );
      })
    }
  </Fragment>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">publications</h1>
    </header>

    <article>
      <BibSearch
        client:load
        entries={entries}
        maxAuthorLimit={maxAuthorLimit}
        showThumbnails={showThumbnails}
        authorLastName={authorLastName}
        previewDir={previewDir}
        pdfDir={pdfDir}
        labels={labels}
        detailBase={site.base}
        coauthors={coauthors}
        citations={citations}
        scholarUserId={scholarUserId}
        badges={badges}
      />
    </article>
  </div>
</Page>

{showAltmetric && <script is:inline src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js" />}

{showDimensions && <script is:inline async src="https://badge.dimensions.ai/badge.js" />}
