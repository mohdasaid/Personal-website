---
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const allBooks = await getCollection('books');

// Determine the display year for a book: prefer `started`, fall back to `finished`
function displayYear(book: (typeof allBooks)[number]): number | null {
  const d = book.data.started ?? book.data.finished;
  return d ? d.getFullYear() : null;
}

// Separate books with a year from those without
const booksWithYear = allBooks.filter((b) => displayYear(b) !== null);
const booksWithoutYear = allBooks.filter((b) => displayYear(b) === null);

// Collect unique years, most recent first
const years = [...new Set(booksWithYear.map((b) => displayYear(b) as number))].sort(
  (a, b) => b - a,
);

// Group books by year, sorted by importance within each group
function booksForYear(year: number) {
  return booksWithYear
    .filter((b) => displayYear(b) === year)
    .sort((a, b) => (a.data.importance ?? 999) - (b.data.importance ?? 999));
}

// Status badge config
const statusConfig: Record<string, { label: string; color: string; icon: string }> = {
  reading: { label: 'reading', color: 'var(--global-theme-color)', icon: 'fa-solid:book-open' },
  finished: { label: 'finished', color: '#4caf50', icon: 'fa-solid:check' },
  queued: { label: 'queued', color: '#9e9e9e', icon: 'fa-solid:clock' },
  paused: { label: 'paused', color: '#ff9800', icon: 'fa-solid:pause' },
  abandoned: { label: 'abandoned', color: '#f44336', icon: 'fa-solid:times' },
  interested: { label: 'interested', color: '#2196f3', icon: 'fa-solid:eye' },
  reread: { label: 'reread', color: '#9c27b0', icon: 'fa-solid:redo' },
};

function coverUrl(book: (typeof allBooks)[number]): string {
  if (book.data.cover) return book.data.cover;
  if (book.data.olid) return `https://covers.openlibrary.org/b/olid/${book.data.olid}-L.jpg`;
  if (book.data.isbn) return `https://covers.openlibrary.org/b/isbn/${book.data.isbn}-L.jpg`;
  return '';
}

function renderStars(stars: number | undefined): string {
  if (!stars) return '';
  const filled = '★'.repeat(stars);
  const empty = '☆'.repeat(5 - stars);
  return filled + empty;
}
---

<Page title="Books" description={`Bookshelf of ${site.author.name}`}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">bookshelf</h1>
    </header>

    <article>
      <blockquote class="sagan-quote">
        <p>"A book is proof that humans are capable of working magic."</p>
        <footer>— Carl Sagan</footer>
      </blockquote>

      <h2 class="books-heading">Books that I am reading, have read, or will read</h2>

      {
        years.map((year) => (
          <section class="year-section">
            <h3 class="year-label">{year}</h3>
            <div class="books-grid">
              {booksForYear(year).map((book) => {
                const src = coverUrl(book);
                const status = book.data.status;
                const badge = status ? statusConfig[status] : undefined;
                const stars = renderStars(book.data.stars);
                return (
                  <div class="book-card" title={`${book.data.title} — ${book.data.author}`}>
                    <div class="cover-wrapper">
                      {src ? (
                        <img
                          src={src}
                          alt={`Cover of ${book.data.title}`}
                          loading="lazy"
                          width="120"
                          height="175"
                          class="cover-img"
                          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                        />
                      ) : null}
                      <div class="cover-placeholder" style={src ? 'display:none' : ''}>
                        <span class="placeholder-title">{book.data.title}</span>
                        <span class="placeholder-author">{book.data.author}</span>
                      </div>
                    </div>

                    {badge && (
                      <span class="status-badge" style={`background-color: ${badge.color}`}>
                        <Icon
                          name={badge.icon}
                          style="font-size: 0.65em; margin-right: 0.2em;"
                          aria-hidden="true"
                        />
                        {badge.label}
                      </span>
                    )}

                    <div class="book-info">
                      <span class="book-title">{book.data.title}</span>
                      <span class="book-author">{book.data.author}</span>
                      {stars && (
                        <span class="book-stars" aria-label={`${book.data.stars} out of 5 stars`}>
                          {stars}
                        </span>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        ))
      }

      {
        booksWithoutYear.length > 0 && (
          <section class="year-section">
            <h3 class="year-label">to read</h3>
            <div class="books-grid">
              {booksWithoutYear
                .sort((a, b) => (a.data.importance ?? 999) - (b.data.importance ?? 999))
                .map((book) => {
                  const src = coverUrl(book);
                  const status = book.data.status;
                  const badge = status ? statusConfig[status] : undefined;
                  const stars = renderStars(book.data.stars);
                  return (
                    <div class="book-card" title={`${book.data.title} — ${book.data.author}`}>
                      <div class="cover-wrapper">
                        {src ? (
                          <img
                            src={src}
                            alt={`Cover of ${book.data.title}`}
                            loading="lazy"
                            class="cover-img"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                          />
                        ) : null}
                        <div class="cover-placeholder" style={src ? 'display:none' : ''}>
                          <span class="placeholder-title">{book.data.title}</span>
                          <span class="placeholder-author">{book.data.author}</span>
                        </div>
                      </div>

                      {badge && (
                        <span class="status-badge" style={`background-color: ${badge.color}`}>
                          <Icon
                            name={badge.icon}
                            style="font-size: 0.65em; margin-right: 0.2em;"
                            aria-hidden="true"
                          />
                          {badge.label}
                        </span>
                      )}

                      <div class="book-info">
                        <span class="book-title">{book.data.title}</span>
                        <span class="book-author">{book.data.author}</span>
                        {stars && (
                          <span class="book-stars" aria-label={`${book.data.stars} out of 5 stars`}>
                            {stars}
                          </span>
                        )}
                      </div>
                    </div>
                  );
                })}
            </div>
          </section>
        )
      }

      {allBooks.length === 0 && <p style="color: var(--global-text-color-light);">No books yet.</p>}
    </article>
  </div>
</Page>

<style>
  /* ── Page structure ─────────────────────────────────────────────────────── */
  .post {
    padding-top: 0;
  }

  /* ── Carl Sagan quote ───────────────────────────────────────────────────── */
  .sagan-quote {
    border-left: 3px solid var(--global-theme-color);
    margin: 0 0 2rem 0;
    padding: 0.5rem 1.25rem;
    color: var(--global-text-color-light);
    font-style: italic;
  }

  .sagan-quote p {
    margin: 0 0 0.25rem 0;
    font-size: 1.1rem;
  }

  .sagan-quote footer {
    font-size: 0.875rem;
    color: var(--global-text-color-light);
    font-style: normal;
  }

  /* ── Section headings ───────────────────────────────────────────────────── */
  .books-heading {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--global-text-color);
    font-family: var(--font-sans);
    margin-bottom: 1.5rem;
  }

  .year-section {
    margin-bottom: 2.5rem;
  }

  .year-label {
    color: var(--global-divider-color);
    border-bottom: 1px solid var(--global-divider-color);
    padding-bottom: 0.25rem;
    margin-bottom: 1.25rem;
    text-align: right;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
  }

  /* ── Books grid ─────────────────────────────────────────────────────────── */
  .books-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  /* ── Book card ──────────────────────────────────────────────────────────── */
  .book-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 120px;
    gap: 0.4rem;
    transition: transform 0.2s ease;
  }

  .book-card:hover {
    transform: translateY(-3px);
  }

  .cover-wrapper {
    width: 120px;
    height: 175px;
    border-radius: 3px;
    overflow: hidden;
    box-shadow: 2px 3px 8px rgba(0, 0, 0, 0.2);
    background-color: var(--global-card-bg-color);
    border: 1px solid var(--global-divider-color);
    position: relative;
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
    text-align: center;
    gap: 0.4rem;
    background-color: var(--global-card-bg-color);
  }

  .placeholder-title {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--global-text-color);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .placeholder-author {
    font-size: 0.65rem;
    color: var(--global-text-color-light);
    line-height: 1.2;
  }

  /* ── Status badge ───────────────────────────────────────────────────────── */
  .status-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
    white-space: nowrap;
  }

  /* ── Book info caption ──────────────────────────────────────────────────── */
  .book-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.1rem;
    width: 100%;
  }

  .book-title {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--global-text-color);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .book-author {
    font-size: 0.65rem;
    color: var(--global-text-color-light);
    line-height: 1.2;
  }

  .book-stars {
    font-size: 0.75rem;
    color: var(--global-theme-color);
    letter-spacing: 0.05em;
  }
</style>
