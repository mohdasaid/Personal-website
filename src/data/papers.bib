% Bibliography for demo publications page.
% BibTeX entries following al-folio conventions.
%
% Custom fields supported by as-folio:
%   abbr             = short venue badge (e.g. PhysRev, Nature)
%   abstract         = shown in collapsible abstract block
%   selected         = {true} to show in "Selected Publications" on about page
%   preview          = path to thumbnail image in /assets/img/publication_preview/
%   arxiv            = arXiv ID (e.g. 1234.56789) — auto-links to arxiv.org/abs/
%   html             = URL to paper landing page (HTML version)
%   pdf              = path or URL to PDF
%   code             = URL to code repository
%   poster           = path to poster PDF
%   slides           = path to slides PDF
%   video            = URL to video presentation
%   supp             = URL to supplementary material
%   blog             = URL to blog post about this paper
%   website          = URL to project website
%   award            = award text (e.g. "Best Paper Award")
%   award_name       = short award label badge
%   bibtex_show      = {true} to show BibTeX citation button
%   annotation       = short note shown as info tooltip in author line
%   additional_info  = extra text shown after venue/year (e.g. workshop info)
%   google_scholar_id = paper-level Scholar ID for citation badge
%   altmetric        = {true} to use DOI/arXiv for Altmetric badge, or explicit ID
%   dimensions       = {true} to use DOI for Dimensions badge, or explicit ID
%   inspirehep_id    = InspireHEP literature record ID for citation badge

% ─── 1905 Annus Mirabilis papers ─────────────────────────────────────────────

@article{einstein1905photoelectric,
  abbr             = {Ann. Phys.},
  title            = {On a Heuristic Point of View about the Creation and Conversion of Light},
  author           = {Einstein, Albert},
  journal          = {Annalen der Physik},
  volume           = {322},
  number           = {6},
  pages            = {132--148},
  year             = {1905},
  doi              = {10.1002/andp.19053220607},
  html             = {https://doi.org/10.1002/andp.19053220607},
  pdf              = {example_pdf.pdf},
  slides           = {example_pdf.pdf},
  video            = {https://www.youtube.com/watch?v=dQw4w9WgXcQ},
  blog             = {https://example.com/einstein-photoelectric-blog},
  additional_info  = {Basis for the 1921 Nobel Prize in Physics.},
  abstract         = {There exists a profound formal difference between the theoretical representations of gases and other ponderable bodies currently used by physicists on the one hand, and Maxwell's theory of electromagnetic processes in so-called empty space on the other. Whereas we regard the state of a body as being completely determined by the positions and velocities of a quite finite number of atoms and electrons, we use for the determination of the electromagnetic state in space continuous spatial functions, so that a finite number of variables cannot be regarded as sufficient for the complete description of such a state.},
  selected         = {true},
  bibtex_show      = {true},
  award            = {Nobel Prize, 1921},
  award_name       = {Nobel Prize}
}

